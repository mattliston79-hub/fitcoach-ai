{
  "functions": {
    "api/chat.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/send-weekly-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/send-questionnaire-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
